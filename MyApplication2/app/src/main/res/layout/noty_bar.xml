<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="80dp"
    android:padding="8dp"
    >

    <ImageView
        android:id="@+id/noty_img_album"
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_img_default" />

    <LinearLayout
        android:id="@+id/noty_text_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/noty_img_album"
        android:layout_toStartOf="@+id/noty_controls"
        android:layout_centerVertical="true"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/noty_txt_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Titre de la musique"
            android:textColor="@color/noty_title"
            android:textSize="15sp"
            android:textStyle="bold"
            android:ellipsize="marquee"
            android:singleLine="true" />

        <TextView
            android:id="@+id/noty_txt_artist"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Artiste"
            android:textColor="@color/noty_artist"
            android:textSize="13sp"
            android:ellipsize="end"
            android:singleLine="true" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/noty_controls"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:orientation="horizontal">

        <ImageView
            android:id="@+id/noty_btn_prev"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:padding="8dp"
            android:src="@drawable/btn_prev"
            android:tint="@color/noty_icon_tint"
            android:contentDescription="Précédent" />

        <ImageView
            android:id="@+id/noty_btn_play_pause"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:padding="6dp"
            android:src="@drawable/btn_pause"
            android:tint="@color/noty_icon_tint"
            android:contentDescription="Play Pause" />

        <ImageView
            android:id="@+id/noty_btn_next"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:padding="8dp"
            android:src="@drawable/btn_next"
            android:tint="@color/noty_icon_tint"
            android:contentDescription="Suivant" />
    </LinearLayout>
</RelativeLayout>