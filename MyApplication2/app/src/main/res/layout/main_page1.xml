<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <include
        android:id="@+id/included_toolbar"
        layout="@layout/layout_toolbar"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/txt_last_imc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Dernier IMC : --"
        android:textSize="16sp"
        android:textStyle="bold"
        android:visibility="gone"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/included_toolbar" />

    <!-- Le Flow gère le placement automatique des boutons -->
    <androidx.constraintlayout.helper.widget.Flow
        android:id="@+id/flow_menu"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:padding="24dp"
        app:constraint_referenced_ids="btn_music_glossy,btn_food"
        app:flow_horizontalGap="24dp"
        app:flow_verticalGap="24dp"
        app:flow_wrapMode="aligned"
        app:flow_horizontalStyle="packed"
        app:flow_verticalStyle="packed"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txt_last_imc" />

    <FrameLayout
        android:id="@+id/btn_music_glossy"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:background="@drawable/button_glossy"
        android:clickable="true"
        android:elevation="6dp"
        android:focusable="true"
        tools:ignore="MissingConstraints">

        <ImageView
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_music"
            app:tint="@color/purple_700" />

    </FrameLayout>

    <FrameLayout
        android:id="@+id/btn_food"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:background="@drawable/button_glossy"
        android:clickable="true"
        android:elevation="6dp"
        android:focusable="true"
        tools:ignore="MissingConstraints">

        <ImageView
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_meat"
            app:tint="@color/purple_700" />

    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>